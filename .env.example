# Dashboard auth
# If unset, the dashboard runs in local-unlocked mode.
DASHBOARD_PASSWORD=
SESSION_SECRET=change-this-in-real-use

# Optional OIDC / SSO login
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:4177/auth/oidc/callback
OIDC_SCOPE=openid profile email

# Optional provider admin credentials.
# Keep these in your shell or .env file; they are never sent to the browser.
OPENAI_ADMIN_KEY=
ANTHROPIC_ADMIN_KEY=
ANTHROPIC_WORKSPACE_ID=
ANTHROPIC_API_CACHE_SECONDS=60

# Local data sources
CODEX_HOME=~/.codex
CODEX_LIVE_RATE_LIMITS=true
CODEX_LIVE_RATE_LIMITS_CACHE_SECONDS=15
CLAUDE_HOME=~/.claude
GEMINI_HOME=~/.gemini
OLLAMA_HOST=http://localhost:11434
OLLAMA_PROXY_PORT=11435
PORT=4177
