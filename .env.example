# Dashboard auth
# If unset, the dashboard runs in local-unlocked mode.
DASHBOARD_PASSWORD=
SESSION_SECRET=change-this-in-real-use

# Optional OIDC / SSO login
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:4177/auth/oidc/callback
OIDC_SCOPE=openid profile email

# Optional provider admin credentials.
# Keep these in your shell or .env file; they are never sent to the browser.
OPENAI_ADMIN_KEY=
ANTHROPIC_ADMIN_KEY=
ANTHROPIC_WORKSPACE_ID=
ANTHROPIC_API_CACHE_SECONDS=60

# Optional runtime data directory override for connected sources and usage cache files.
# `LLM_USAGE_DATA_DIR` is preferred; `DATA_DIR` is kept as a compatibility fallback.
LLM_USAGE_DATA_DIR=./data
DATA_DIR=

# Local data sources
CODEX_HOME=~/.codex
LLM_USAGE_CODEX_HOMES=
CODEX_LIVE_RATE_LIMITS=true
CODEX_LIVE_RATE_LIMITS_CACHE_SECONDS=15
COPILOT_HOME=~/.copilot
CLAUDE_HOME=~/.claude
GEMINI_HOME=~/.gemini
OLLAMA_HOST=http://localhost:11434
OLLAMA_PROXY_PORT=11435
PORT=4177

# Optional resource tuning. Idle cache values apply while no dashboard client
# is actively polling; background notification checks accept usage data up to
# NOTIFICATION_USAGE_MAX_AGE_SECONDS old instead of triggering a full rescan.
# NOTIFICATION_USAGE_MAX_AGE_SECONDS=600
# CODEX_LIVE_RATE_LIMITS_IDLE_CACHE_SECONDS=600
# COPILOT_LIVE_QUOTA_IDLE_CACHE_SECONDS=900
# CLAUDE_AUTH_STATUS_CACHE_SECONDS=900
# OPENAI_API_CACHE_SECONDS=300
