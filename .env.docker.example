# Copy to .env before running `docker compose up --build`.

# The dashboard is local-unlocked when this is empty. Set a password if the
# machine is shared or the port is exposed beyond localhost.
DASHBOARD_PASSWORD=
SESSION_SECRET=change-this-to-a-long-random-string

# Host ports.
PORT=4177
OLLAMA_PROXY_PORT=11435

# Optional provider admin credentials.
OPENAI_ADMIN_KEY=
ANTHROPIC_ADMIN_KEY=

# Optional SSO/OIDC.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:4177/auth/oidc/callback
OIDC_SCOPE=openid profile email

# From inside Docker, Ollama on the Linux host is reached through
# host.docker.internal via docker-compose.yml's host-gateway mapping.
OLLAMA_HOST=http://host.docker.internal:11434
